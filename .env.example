# E2KB Engine - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# EMAIL CONFIGURATION (for notifications)
# =============================================================================
# To get an App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Base URL for download links in emails
BASE_URL=http://localhost:3000

# =============================================================================
# VLM API CONFIGURATION (for Premium PDF processing)
# =============================================================================
# Configure ONE of these APIs for Premium mode (formulas, diagrams, images)
# Leave empty to use only Basic mode (free OCR extraction)

# Claude API (recommended) - https://console.anthropic.com/
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI API (alternative) - https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
